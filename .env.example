# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google OAuth – download from Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# Agent behaviour
POLL_INTERVAL_MINUTES=5
FOLLOW_UP_HOURS=24
UNREAD_GOAL=10

# Database
DATABASE_PATH=inboxpilot.db

# Priority escalation
# ESCALATION_ENABLED=true          # Set to false to disable escalation entirely
# ESCALATION_MIN_PRIORITY=7        # Only track emails at or above this priority
# ESCALATION_HOURS=12              # Hours unread before each escalation step
# ESCALATION_STEP=2                # Priority points added per escalation
# ESCALATION_MAX_PRIORITY=10       # Hard cap on escalated priority
